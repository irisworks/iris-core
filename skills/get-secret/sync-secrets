#!/usr/bin/env bash
# sync-secrets — dump all Azure Key Vault secrets to /iris/.secrets.env
# Run this on host after any secret change. All containers mount this file.
set -euo pipefail

KV="${IRIS_KEY_VAULT:?IRIS_KEY_VAULT not set}"
OUT="/iris/.secrets.env"
TMPFILE=$(mktemp)

echo "# Auto-generated by sync-secrets — do not edit manually" > "$TMPFILE"
echo "# Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$TMPFILE"
echo "" >> "$TMPFILE"

SECRET_NAMES=$(az keyvault secret list --vault-name "$KV" --query "[].name" -o tsv)

for name in $SECRET_NAMES; do
  value=$(az keyvault secret show --vault-name "$KV" --name "$name" --query value -o tsv 2>/dev/null || true)
  if [[ -n "$value" ]]; then
    env_var=$(echo "$name" | tr '-' '_')
    echo "${env_var}=${value}" >> "$TMPFILE"
  fi
done

mv "$TMPFILE" "$OUT"
chmod 600 "$OUT"
echo "Synced $(echo "$SECRET_NAMES" | wc -w | tr -d ' ') secrets to $OUT"
