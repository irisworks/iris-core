#!/usr/bin/env bash
# get-secret — thin client for Iris's internal /secrets/:name route.
# Resolution (env var, Key Vault, or IRIS_SECRET_BROKER_URL) happens
# server-side in api.ts; this script just authenticates and calls it.
set -euo pipefail

SECRET_NAME="${1:?Usage: get-secret <SECRET_NAME>}"

# On Iris's own host, the API is loopback. Inside a sub-agent container it's
# reachable via IRIS_API_URL (the Docker gateway address), same as self-heal
# uses for escalation.
#
# Caller identity is derived server-side from IRIS_API_TOKEN itself: agents
# provisioned with their own per-agent token (terraform/modules/agent's
# api_token output, registered as agents.json[name].token) are identified as
# that agent; anyone presenting the shared token is unrestricted "iris".
API_BASE="${IRIS_API_URL:-http://127.0.0.1:${IRIS_API_PORT:-3000}}"

RESPONSE=$(curl -sf \
  -H "Authorization: Bearer ${IRIS_API_TOKEN:-}" \
  "${API_BASE}/secrets/${SECRET_NAME}") || {
  echo "get-secret: failed to retrieve '${SECRET_NAME}' (agent '${AGENT_NAME:-iris}')" >&2
  exit 1
}

echo "$RESPONSE" | jq -r .value
