#!/usr/bin/env bash
# set-secret — write path counterpart to get-secret.
#   set-secret request NAME [--channel <id>] [--ttl <seconds>]  → mint a drop link
#   printf '%s' "$VALUE" | set-secret NAME [--proxy-only]       → store from stdin
# Both are thin clients for Iris's internal API (api.ts); storage happens in
# the encrypted store / broker daemon server-side.
set -euo pipefail

API_BASE="${IRIS_API_URL:-http://127.0.0.1:${IRIS_API_PORT:-3000}}"
AUTH=(-H "Authorization: Bearer ${IRIS_API_TOKEN:-}")

if [[ "${1:-}" == "request" ]]; then
  SECRET_NAME="${2:?Usage: set-secret request <SECRET_NAME> [--channel <id>] [--ttl <seconds>]}"
  shift 2
  CHANNEL=""
  TTL=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --channel) CHANNEL="${2:?--channel needs a value}"; shift 2 ;;
      --ttl) TTL="${2:?--ttl needs a value}"; shift 2 ;;
      *) echo "set-secret: unknown option '$1'" >&2; exit 1 ;;
    esac
  done
  BODY=$(jq -n --arg name "$SECRET_NAME" --arg channel "$CHANNEL" --arg ttl "$TTL" \
    '{name: $name}
     + (if $channel != "" then {channelId: $channel} else {} end)
     + (if $ttl != "" then {ttlSeconds: ($ttl | tonumber)} else {} end)')
  RESPONSE=$(curl -sf "${AUTH[@]}" -H "Content-Type: application/json" \
    -d "$BODY" "${API_BASE}/secret-drops") || {
    echo "set-secret: failed to create drop link for '${SECRET_NAME}'" >&2
    exit 1
  }
  echo "$RESPONSE" | jq -r --arg name "$SECRET_NAME" \
    '"Drop link for \($name) — single-use, expires \(.expiresAt):", (.url // .path)'
  exit 0
fi

SECRET_NAME="${1:?Usage: set-secret <SECRET_NAME> [--proxy-only]  (value on stdin) | set-secret request <SECRET_NAME>}"
shift
PROXY_ONLY=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --proxy-only) PROXY_ONLY=true; shift ;;
    *) echo "set-secret: unknown option '$1'" >&2; exit 1 ;;
  esac
done

if [[ -t 0 ]]; then
  echo "set-secret: pass the value on stdin, e.g.  printf '%s' \"\$VALUE\" | set-secret ${SECRET_NAME}" >&2
  exit 1
fi

# jq -Rs wraps arbitrary stdin (including newlines/quotes) safely into JSON.
BODY=$(jq -Rs --argjson proxyOnly "$PROXY_ONLY" '{value: ., proxyOnly: $proxyOnly}')
curl -sf "${AUTH[@]}" -H "Content-Type: application/json" \
  -X PUT -d "$BODY" "${API_BASE}/secrets/${SECRET_NAME}" > /dev/null || {
  echo "set-secret: failed to store '${SECRET_NAME}' (backend not configured, or caller not iris)" >&2
  exit 1
}
echo "set-secret: stored '${SECRET_NAME}'"
